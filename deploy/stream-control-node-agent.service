[Unit]
Description=Stream Control Hub Node Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=streamdash
Group=streamdash
WorkingDirectory=/opt/stream-control-hub
Environment=PYTHONUNBUFFERED=1
Environment=PORT=8787
Environment=STREAM_CONTROL_ROLE=agent
Environment=STREAM_NODE_AGENT_MODE=1
Environment=STREAM_NODE_AGENT_NAME=%H
Environment=CONTROL_HUB_URL=http://127.0.0.1:8788
Environment=STREAM_UPLOAD_DIR=/srv/stream-videos
Environment=STREAM_LOG_FILE=/var/log/stream-control-node-agent/stream.log
Environment=STREAM_CONFIG_FILE=/opt/stream-control-hub/stream_config.json
Environment=STREAM_TUNING_FILE=/opt/stream-control-hub/stream_tuning.json
Environment=STREAM_RUNTIME_FILE=/opt/stream-control-hub/stream_runtime_state.json
Environment=STREAM_PID_FILE=/run/stream-control-node-agent/ffmpeg.pid
Environment=CHAT_PLAN_FILE=/opt/stream-control-hub/chat_plan.json
Environment=YOUTUBE_CLIENT_FILE=/opt/stream-control-hub/youtube_client.json
Environment=YOUTUBE_TOKEN_FILE=/opt/stream-control-hub/youtube_token.json
Environment=DASHBOARD_SECRET_FILE=/opt/stream-control-hub/dashboard_secret.key
Environment=DASHBOARD_PASSWORD_FILE=/opt/stream-control-hub/dashboard_password.txt
Environment=PUBLIC_UPLOAD_FIREWALL=none
Environment=PUBLIC_UPLOAD_RESTRICT=1
Environment=PUBLIC_UPLOAD_CLOSE_ON_START=1
Environment=STREAM_AUTORESTART_ENABLED=1
Environment=STREAM_RELAY_ENABLED=0
RuntimeDirectory=stream-control-node-agent
ExecStart=/opt/stream-control-hub/.venv/bin/gunicorn --worker-class gthread --workers 1 --threads 4 --timeout 3600 --graceful-timeout 30 --bind 127.0.0.1:8787 stream_control_hub.node_agent.wsgi:APP
KillMode=process
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
